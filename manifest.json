{
    "name": "Kamikire",
    "description": "New tab notepad with multi-service search, tasks and live text statistics.",
    "version": "1.0",
    "manifest_version": 3,
    "permissions": ["storage", "tabs"],
    "icons": {
        "16": "icons/icon16.png",
        "32": "icons/icon32.png",
        "48": "icons/icon48.png",
        "128": "icons/icon128.png"
    },
    "action": {
        "default_icon": {
            "16": "icons/icon16.png",
            "32": "icons/icon32.png",
            "48": "icons/icon48.png"
        }
    },
    "chrome_url_overrides": {
        "newtab": "index.html"
    }
}
